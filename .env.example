# OAuth 2.0 (Google) — create credentials at https://console.cloud.google.com/apis/credentials
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Must match the authorized redirect URI in Google Cloud Console
CALLBACK_URL=http://localhost:3000/auth/google/callback

# Secrets — change in production
JWT_SECRET=change_me_in_production
SESSION_SECRET=change_me_too

# Used only when running the Node app outside Docker (optional)
# DATABASE_URL=postgres://locuser:locpass@localhost:5432/locationdb
# KAFKA_BROKERS=localhost:9092
